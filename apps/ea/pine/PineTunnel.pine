//=========================================================================
//! RC4 ENCRYPTION
// -------------------------------------------------------------------
// RC4-drop256 stream cipher with XOR-fold integrity checksum.
// Format: RC4,<nonce_hex>:<ciphertext_hex>:<checksum_hex>
// Server auto-detects and decrypts. Plaintext still works.
// -------------------------------------------------------------------

// Byte-level XOR (PineScript has no bitwise ops - uses arithmetic)
_xor8(int a, int b) =>
    int result = 0
    int weight = 1
    for bit_pos = 0 to 7
        int ba = (a / weight) % 2
        int bb = (b / weight) % 2
        int bx = ba != bb ? 1 : 0
        result := result + bx * weight
        weight := weight * 2
    result

// RC4 Key Scheduling Algorithm
_rc4Ksa(array<int> key_bytes) =>
    array<int> s = array.new_int(256, 0)
    for i = 0 to 255
        array.set(s, i, i)
    int j = 0
    int key_len = array.size(key_bytes)
    for i = 0 to 255
        int ki = array.get(key_bytes, i % key_len)
        j := (j + array.get(s, i) + ki) % 256
        int tmp = array.get(s, i)
        array.set(s, i, array.get(s, j))
        array.set(s, j, tmp)
    s

// RC4 Pseudo-Random Generation Algorithm
_rc4Prga(array<int> s, int n) =>
    int i = 0
    int j = 0
    array<int> ks = array.new_int(n, 0)
    for idx = 0 to n - 1
        i := (i + 1) % 256
        j := (j + array.get(s, i)) % 256
        int tmp = array.get(s, i)
        array.set(s, i, array.get(s, j))
        array.set(s, j, tmp)
        array.set(ks, idx, array.get(s, (array.get(s, i) + array.get(s, j)) % 256))
    ks

// ASCII lookup for string-to-bytes
_asciiTable() =>
    " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

_strToBytes(string src) =>
    string ascii_chars = _asciiTable()
    array<int> bytes = array.new_int(0, 0)
    for ci = 0 to str.length(src) - 1
        string char_val = str.substring(src, ci, ci + 1)
        int pos_val = str.pos(ascii_chars, char_val)
        int code_val = pos_val >= 0 ? pos_val + 32 : 32
        array.push(bytes, code_val)
    bytes

_hexVal(string c) =>
    string digits = "0123456789abcdef"
    str.pos(digits, str.lower(c))

_hexToBytes(string hex_str) =>
    string h = str.lower(hex_str)
    array<int> result = array.new_int(0, 0)
    int idx = 0
    while idx < str.length(h) - 1
        int hi = _hexVal(str.substring(h, idx, idx + 1))
        int lo = _hexVal(str.substring(h, idx + 1, idx + 2))
        if hi >= 0 and lo >= 0
            array.push(result, hi * 16 + lo)
        idx := idx + 2
    result

_bytesToHex(array<int> bytes) =>
    string hex = ""
    string hex_chars = "0123456789abcdef"
    for i = 0 to array.size(bytes) - 1
        int b = array.get(bytes, i)
        int hi_idx = b / 16
        int lo_idx = b % 16
        hex := hex + str.substring(hex_chars, hi_idx, hi_idx + 1) + str.substring(hex_chars, lo_idx, lo_idx + 1)
    hex

_xorFold(array<int> data, int n) =>
    array<int> result = array.new_int(n, 0)
    for i = 0 to array.size(data) - 1
        int idx = i % n
        array.set(result, idx, _xor8(array.get(result, idx), array.get(data, i)))
    result

// Generate 8-byte nonce from bar time + bar_index
_genNonce() =>
    int t = int(time)
    array<int> nonce = array.new_int(8, 0)
    nonce.set(0, (t / 72057594037927936) % 256)
    nonce.set(1, (t / 281474976710656) % 256)
    nonce.set(2, (t / 1099511627776) % 256)
    nonce.set(3, (t / 4294967296) % 256)
    nonce.set(4, (t / 16777216) % 256)
    nonce.set(5, (t / 65536) % 256)
    nonce.set(6, (t / 256) % 256)
    nonce.set(7, t % 256)
    nonce.set(7, _xor8(array.get(nonce, 7), bar_index % 256))
    nonce

// RC4 encrypt with drop-256
_rc4Encrypt(array<int> key_bytes, array<int> nonce, array<int> plaintext) =>
    array<int> combined = array.new_int(0, 0)
    for i = 0 to array.size(key_bytes) - 1
        array.push(combined, array.get(key_bytes, i))
    for i = 0 to array.size(nonce) - 1
        array.push(combined, array.get(nonce, i))
    array<int> s = _rc4Ksa(combined)
    _rc4Prga(s, 256)
    array<int> ks = _rc4Prga(s, array.size(plaintext))
    array<int> ct = array.new_int(array.size(plaintext), 0)
    for i = 0 to array.size(plaintext) - 1
        array.set(ct, i, _xor8(array.get(plaintext, i), array.get(ks, i)))
    ct

//@function Encrypt a plaintext signal string with RC4-drop256
//@param plaintext The CSV signal string to encrypt
//@param encKey 64-char hex encryption key (from pinetunnel setup)
//@returns Encrypted string in format RC4,<nonce>:<ciphertext>:<checksum>, or plaintext if key is empty/invalid
export encrypt(string plaintext, string encKey) =>
    string _return = plaintext
    if encKey != "" and str.length(encKey) == 64
        array<int> keyBytes = _hexToBytes(encKey)
        array<int> nonce = _genNonce()
        array<int> ptBytes = _strToBytes(plaintext)
        array<int> ctBytes = _rc4Encrypt(keyBytes, nonce, ptBytes)
        array<int> checksum = _xorFold(ctBytes, 4)
        _return := "RC4," + _bytesToHex(nonce) + ":" + _bytesToHex(ctBytes) + ":" + _bytesToHex(checksum)
    _return

//@function Send an encrypted PineTunnel alert. Encrypts with RC4 if encKey is set, otherwise sends plaintext.
//@param licenseID Your PineTunnel license ID
//@param command Trading command (buy, sell, close_long, etc.)
//@param symbol Trading symbol
//@param parameters Optional parameters string
//@param acc_filter Optional minimum account balance
//@param comment Optional trade comment (max 20 chars)
//@param secret Optional webhook secret key
//@param encKey 64-char hex encryption key (from pinetunnel setup, SIGNAL_ENCRYPTION_KEY in .env)
//@param freq Alert frequency: "all", "once_per_bar", "once_per_bar_close"
//@param debugLabel Show debug label on chart
//@returns The alert string that was sent (encrypted or plaintext)
export pt_order_encrypted(string licenseID,
                          string command,
                          string symbol = syminfo.ticker,
                          string parameters = "",
                          float acc_filter = na,
                          string comment = "",
                          string secret = "",
                          string encKey = "",
                          string freq = "all",
                          bool debugLabel = false) =>
    string plaintext = licenseID + "," + command + "," + symbol
    if parameters != ""
        plaintext := plaintext + (not str.startswith(parameters, ",") ? "," + parameters : parameters)
    if not na(acc_filter)
        plaintext := plaintext + ",acc_filter=" + str.tostring(acc_filter)
    if comment != ""
        plaintext := plaintext + (not str.startswith(comment, ",") ? ",comment=" + comment : comment)
    if secret != ""
        plaintext := plaintext + (not str.startswith(secret, ",") ? ",secret=" + secret : secret)
    if str.endswith(plaintext, ",")
        plaintext := str.substring(plaintext, 0, str.length(plaintext) - 1)
    string alertMsg = encrypt(plaintext, encKey)
    debug(alertMsg, debugLabel)
    if freq == "all"
        alert(alertMsg, alert.freq_all)
    else if freq == "once_per_bar"
        alert(alertMsg, alert.freq_once_per_bar)
    else if freq == "once_per_bar_close"
        alert(alertMsg, alert.freq_once_per_bar_close)
    alertMsg

// }
// END RC4 ENCRYPTION
//=========================================================================
