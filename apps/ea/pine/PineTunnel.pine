//@version=6
//@description PineTunnel bridge library. Sends encrypted or plaintext trading signals to MetaTrader via alert(). RC4-drop256 encryption with integrity checksum. 40+ commands, all PineTunnel parameters supported.
//@library
library("PineTunnel", overlay = true)

//=========================================================================
//! MISC FUNCTIONS
//{

//@function Returns "all" for use as freq parameter
export all() => "all"

//@function Returns "once_per_bar" for use as freq parameter
export once_per_bar() => "once_per_bar"

//@function Returns "once_per_bar_close" for use as freq parameter
export once_per_bar_close() => "once_per_bar_close"

//@function Checks if value is na or 0
//@param value Value to check
//@returns True if na or 0
export na0(float value) =>
    bool _return = na(value) or value == 0

//@function Truncates a number to string with X decimals
//@param number Number to truncate
//@param decimals Decimal places (default: market mintick decimals)
//@returns Truncated string
export truncate(float number, int decimals = -1) =>
    float _decimals = decimals
    if _decimals == -1
        string price_str = str.tostring(close)
        int dot_pos = str.pos(price_str, ".")
        if dot_pos != -1
            _decimals := str.length(price_str) - dot_pos - 1
        else
            _decimals := 2
    string _formatter = "{0,number,#."
    for i = 0 to int(_decimals) - 1 by 1
        _formatter := _formatter + "#"
    str.format(_formatter + "}", number)

//@function Prints to console and optionally creates debug label
//@param txt Text to display
//@param displayLabel Show chart label (default: false)
export debug(string txt, bool displayLabel = false) =>
    log.warning("\n" + txt)
    if displayLabel
        label.new(bar_index, high, txt, color=color.white, style=label.style_label_down, textcolor=color.black, force_overlay=true)

//}
// END MISC FUNCTIONS
//=========================================================================

//=========================================================================
//! CORE ORDER BUILDER
//{

//@function Builds and fires a PineTunnel alert. All other functions delegate to this.
//@param licenseID Your PineTunnel license ID
//@param command Trading command (buy, sell, close_long, etc.)
//@param symbol Trading symbol (defaults to current chart)
//@param parameters Optional parameter string
//@param acc_filter Optional minimum account balance
//@param comment Optional trade comment (max 20 chars)
//@param secret Optional webhook secret key
//@param freq Alert frequency: "all", "once_per_bar", "once_per_bar_close", or "none"
//@param debugLabel Show debug label on chart
//@returns The alert string that was sent
export pt_order(string licenseID,
                string command,
                string symbol = syminfo.ticker,
                string parameters = "",
                float acc_filter = na,
                string comment = "",
                string secret = "",
                string freq = "all",
                bool debugLabel = false) =>
    string _return = licenseID + "," + command + "," + symbol
    if parameters != ""
        _return := _return + (not str.startswith(parameters, ",") ? "," + parameters : parameters)
    if not na(acc_filter)
        _return := _return + ",acc_filter=" + str.tostring(acc_filter)
    if comment != ""
        _return := _return + (not str.startswith(comment, ",") ? ",comment=" + comment : comment)
    if secret != ""
        _return := _return + (not str.startswith(secret, ",") ? ",secret=" + secret : secret)
    if str.endswith(_return, ",")
        _return := str.substring(_return, 0, str.length(_return) - 1)
    debug(_return, debugLabel)
    if freq == "all"
        alert(_return, alert.freq_all)
    else if freq == "once_per_bar"
        alert(_return, alert.freq_once_per_bar)
    else if freq == "once_per_bar_close"
        alert(_return, alert.freq_once_per_bar_close)
    _return

// }
// END CORE ORDER BUILDER
//=========================================================================

//=========================================================================
//! MARKET ORDERS
//{

//@function Market buy order
export buy(string licenseID,
           float lots = na,
           float usd = na,
           float risk = na,
           float risk_bal_pct = na,
           float risk_eq_pct = na,
           float sl = na,
           float tp = na,
           string symbol = syminfo.ticker,
           float acc_filter = na,
           string comment = "",
           string secret = "",
           string freq = "all",
           bool debugLabel = false) =>
    string _params = ""
    _params := _params + (na(lots) ? "" : ",lots=" + truncate(lots))
    _params := _params + (na(usd) ? "" : ",usd=" + truncate(usd))
    _params := _params + (na(risk) ? "" : ",risk=" + truncate(risk))
    _params := _params + (na(risk_bal_pct) ? "" : ",risk_bal_pct=" + truncate(risk_bal_pct))
    _params := _params + (na(risk_eq_pct) ? "" : ",risk_eq_pct=" + truncate(risk_eq_pct))
    _params := _params + (na(sl) ? "" : ",sl=" + truncate(sl))
    _params := _params + (na(tp) ? "" : ",tp=" + truncate(tp))
    pt_order(licenseID, "buy", symbol, _params, acc_filter, comment, secret, freq, debugLabel)

//@function Market sell order
export sell(string licenseID,
            float lots = na,
            float usd = na,
            float risk = na,
