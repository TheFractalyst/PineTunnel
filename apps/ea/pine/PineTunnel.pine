//=========================================================================
//! EA MANAGEMENT
//{

//@function Turn EA on (resume signal processing)
export ea_on(string licenseID,
             string secret = "",
             string freq = "all",
             bool debugLabel = false) =>
    pt_order(licenseID, "ea_on", "ea_on", "", na, "", secret, freq, debugLabel)

//@function Turn EA off (halt signal processing)
export ea_off(string licenseID,
              string secret = "",
              string freq = "all",
              bool debugLabel = false) =>
    pt_order(licenseID, "ea_off", "ea_off", "", na, "", secret, freq, debugLabel)

//@function Close all positions and turn EA off
export close_all_off(string licenseID,
                     string secret = "",
                     string freq = "all",
                     bool debugLabel = false) =>
    pt_order(licenseID, "close_all_off", "close_all_off", "", na, "", secret, freq, debugLabel)

// }
// END EA MANAGEMENT
