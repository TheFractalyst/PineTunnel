# PineTunnel Environment Variables
# Copy this file to .env and fill in your values

# Server
HOST=127.0.0.1
PORT=8000
APP_ENV=development
DEBUG=true
# REQUIRED: Public base URL for download link generation (used by EA download endpoint)
SERVER_BASE_URL=https://your-server.com
# Comma-separated list of allowed CORS origins (empty = deny all cross-origin)
SERVER_CORS_ORIGINS=https://your-server.com
# Number of Uvicorn workers (1 for WebSocket sticky sessions)
SERVER_WORKERS=1
SERVER_RELOAD=false
# Trusted proxy count for X-Forwarded-For header (1 for Cloudflare, 2 for CF + Render proxy)
TRUSTED_PROXY_COUNT=2

# Data and Logging
DATA_DIR=./data
LOG_LOG_DIR=./data/logs
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
DATABASE_URL=sqlite:///pinetunnel.db

# Redis (for WebSocket state and pub/sub)
REDIS_URL=redis://localhost:6379

# Security - REQUIRED (32+ chars each)
JWT_SECRET=your-jwt-secret-here
WEBHOOK_SECRET=your-webhook-secret-here
ADMIN_API_KEY=your-admin-api-key-here
# Optional: previous admin key for rotation
ADMIN_API_KEY_PREVIOUS=

# TradingView IP Allowlist (optional - restrict webhook to known TV IPs)
TRADINGVIEW_IP_ALLOWLIST=false
TRADINGVIEW_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7

# Security contact info (for /.well-known/security.txt)
SECURITY_EMAIL=security@your-server.com
SECURITY_URL=https://your-server.com/.well-known/security.txt

# Telegram Bot (optional - enables admin bot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ADMIN_IDS=your-telegram-id
TELEGRAM_BOT_URL=https://t.me/your-bot-username

# Signal Encryption (optional - RC4-drop256 for encrypted TradingView alerts)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same key in your PineScript encKey input field.
# Leave empty to accept plaintext signals only.
SIGNAL_ENCRYPTION_KEY=
SIGNAL_ENCRYPTION_KEY_PREVIOUS=

